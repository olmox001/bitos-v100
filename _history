xport function getState(i: number): string { return _stateNames[i] }\" line17=\"    export function getColor(i: number): number { return _colors[i] }\" line18=\"}\" numlines=\"19\"></mutation><next><block type=\"typescript_statement\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" line0=\"APP.register(&quot;Shell&quot;, &quot;S&quot;, &quot;app_shell&quot;, C_TEAL)\" numlines=\"1\"></mutation><next><block type=\"typescript_statement\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" line0=\"APP.register(&quot;File&quot;, &quot;F&quot;, &quot;app_files&quot;, C_ORANGE)\" numlines=\"1\"></mutation><next><block type=\"typescript_statement\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" line0=\"APP.register(&quot;Editor&quot;, &quot;E&quot;, &quot;app_editor&quot;, C_PINK)\" numlines=\"1\"></mutation><next><block type=\"typescript_statement\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" line0=\"APP.register(LANG.t(&quot;Info&quot;, &quot;Info&quot;), &quot;I&quot;, &quot;app_sysinfo&quot;, C_LBLUE)\" numlines=\"1\"></mutation><next><block type=\"typescript_statement\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" line0=\"APP.register(LANG.t(&quot;Sensori&quot;, &quot;Sensors&quot;), &quot;#&quot;, &quot;app_sensors&quot;, C_OK)\" numlines=\"1\"></mutation><next><block type=\"typescript_statement\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" line0=\"APP.register(&quot;Snake&quot;, &quot;~&quot;, &quot;app_snake&quot;, C_OK)\" numlines=\"1\"></mutation><next><block type=\"typescript_statement\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" line0=\"APP.register(LANG.t(&quot;BLE Tast&quot;, &quot;BLE Keys&quot;), &quot;K&quot;, &quot;app_blekeys&quot;, C_PURPLE)\" numlines=\"1\"></mutation><next><block type=\"typescript_statement\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" line0=\"APP.register(LANG.t(&quot;BLE Ctrl&quot;, &quot;BLE Ctrl&quot;), &quot;M&quot;, &quot;app_blectrl&quot;, C_WARN)\" numlines=\"1\"></mutation><next><block type=\"typescri